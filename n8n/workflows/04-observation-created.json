            {
              "leftValue": "={{ $json.parent_id }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "isNotEmpty" }
            }
          ]
        }
      },
      "id": "check-parent",
      "name": "Parent-ID vorhanden?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "operation": "insert",
        "table": "notifications",
        "additionalFields": {},
        "columns": "user_id, child_id, type, title, body"
      },
      "id": "insert-notification",
      "name": "Supabase: In-App Notification schreiben",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [660, 300],
      "credentials": {
        "postgres": {
          "name": "Supabase Postgres (Kita Bergfalke)"
        }
      },
      "notes": "Schreibt Notification NUR für den Elternteil des Kindes (RLS greift automatisch beim Lesen)"
    },
    {
      "parameters": {
        "jsCode": "// Payload für die notifications-Tabelle aufbauen\nconst data = $input.all()[0].json;\n\nconst categoryLabels = {\n  'sprache':       'Sprachentwicklung',\n  'motorik':       'Motorik',\n  'sozial':        'Sozialverhalten',\n  'kreativitaet':  'Kreativität',\n  'mathematik':    'Mathematik/Naturwissenschaft',\n  'selbstaendigkeit': 'Selbständigkeit'\n};\n\nconst categoryLabel = categoryLabels[data.category] || data.category;\n\nreturn [{\n  json: {\n    user_id:  data.parent_id,\n    child_id: data.child_id,\n    type:     'observation_added',\n    title:    `Neue Beobachtung: ${categoryLabel}`,\n    body:     `Eine neue Entwicklungsbeobachtung zu ${data.child_name} wurde von einem Erzieher hinzugefügt.`\n  }\n}];"
      },
      "id": "build-payload",
      "name": "Notification-Payload aufbauen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 460]
    }
  ],
  "connections": {
